{
  "project": "toples_laksana",
  "database": "toples_laksana-db",
  "engine": "MongoDB",
  "orm": "Mongoose",
  "totalCollections": 15,
  "collections": {
    "users": {
      "model": "User",
      "timestamps": { "createdAt": true, "updatedAt": true },
      "fields": {
        "id": { "type": "String", "required": true, "unique": true },
        "authProvider": { "type": "String", "required": true, "enum": ["firebase", "local"], "default": "firebase" },
        "firebaseUid": { "type": "String", "unique": true, "sparse": true },
        "email": { "type": "String", "required": true, "unique": true, "lowercase": true, "trim": true, "index": true },
        "password": { "type": "String", "select": false },
        "fullName": { "type": "String", "default": "" },
        "photoUrl": { "type": "String", "default": "" },
        "phoneNumber": { "type": "String", "default": "" },
        "role": { "type": "String", "required": true, "enum": ["user", "admin", "super_admin"], "default": "user" },
        "isActive": { "type": "Boolean", "default": true },
        "deviceId": { "type": "String", "default": null },
        "isGuest": { "type": "Boolean", "default": true },
        "lastLoginAt": { "type": "Date", "default": null },
        "lastActiveAt": { "type": "Date", "default": null },
        "deletedAt": { "type": "Date", "default": null }
      },
      "methods": ["isAdmin()", "isSuperAdmin()", "softDelete()", "restore()"],
      "statics": ["findOrCreateFromFirebase(payload)", "findAdminByEmail(email)"]
    },

    "products": {
      "model": "Product",
      "timestamps": { "createdAt": true, "updatedAt": true },
      "fields": {
        "id": { "type": "String", "required": true, "unique": true },
        "sku": { "type": "String", "required": true, "unique": true },
        "name": { "type": "String", "required": true },
        "categoryId": { "type": "String", "required": true, "ref": "categories" },
        "productTypeId": { "type": "String", "default": null, "ref": "producttypes" },
        "unitId": { "type": "String", "required": true, "ref": "units" },
        "lidMaterial": { "type": "String", "required": true, "default": "", "ref": "materials" },
        "lidVariant": { "type": "String", "required": true, "default": "", "ref": "lidvariants" },
        "bodyMaterial": { "type": "String", "required": true, "default": "", "ref": "materials" },
        "lidType": { "type": "String", "required": true, "default": "", "ref": "lidtypes" },
        "availabilityStatus": { "type": "String", "required": true, "enum": ["available", "limited", "preorder", "unavailable"], "default": "available" },
        "availabilityNote": { "type": "String", "default": "" },
        "description": { "type": "String", "default": "" },
        "dimension": { "type": "Embedded:Dimension", "default": null },
        "packaging": { "type": "Array<Embedded:Packaging>", "default": [] },
        "images": { "type": "Array<Embedded:ProductImage>", "default": [] },
        "prices": { "type": "Array<Embedded:ProductPrice>", "default": [] },
        "deletedAt": { "type": "Date", "default": null }
      },
      "embeddedSchemas": {
        "Dimension": {
          "_id": false,
          "fields": {
            "heightCm": { "type": "Number", "required": true, "default": 0 },
            "diameterCm": { "type": "Number", "required": true, "default": 0 },
            "volumeMl": { "type": "Number", "required": true, "default": 0 },
            "weightGram": { "type": "Number", "required": true, "default": 0 }
          }
        },
        "Packaging": {
          "_id": false,
          "fields": {
            "lengthCm": { "type": "Number", "default": null },
            "widthCm": { "type": "Number", "default": null },
            "heightCm": { "type": "Number", "default": null },
            "weightKg": { "type": "Number", "default": null },
            "quantityPerPack": { "type": "Number", "required": true }
          }
        },
        "ProductImage": {
          "_id": false,
          "fields": {
            "imageUrl": { "type": "String", "required": true },
            "order": { "type": "Number", "default": 0 },
            "isPrimary": { "type": "Boolean", "default": false },
            "createdAt": { "type": "Date", "default": "Date.now" }
          }
        },
        "ProductPrice": {
          "_id": false,
          "fields": {
            "lidColorId": { "type": "String", "required": true, "ref": "lidcolors" },
            "priceTypeId": { "type": "String", "required": true, "ref": "pricetypes" },
            "price": { "type": "Number", "required": true },
            "validFrom": { "type": "Date", "required": true, "default": "Date.now" },
            "validUntil": { "type": "Date", "default": null }
          }
        }
      },
      "indexes": [
        { "fields": { "categoryId": 1 } },
        { "fields": { "productTypeId": 1 } },
        { "fields": { "availabilityStatus": 1 } },
        { "fields": { "bodyMaterial": 1 } },
        { "fields": { "lidMaterial": 1 } },
        { "fields": { "lidVariant": 1 } },
        { "fields": { "lidType": 1 } }
      ]
    },

    "categories": {
      "model": "Category",
      "timestamps": { "createdAt": true, "updatedAt": true },
      "fields": {
        "id": { "type": "String", "required": true, "unique": true },
        "name": { "type": "String", "required": true, "unique": true },
        "description": { "type": "String", "default": "" }
      }
    },

    "producttypes": {
      "model": "ProductType",
      "timestamps": { "createdAt": true, "updatedAt": false },
      "fields": {
        "id": { "type": "String", "required": true, "unique": true },
        "name": { "type": "String", "required": true, "unique": true }
      }
    },

    "units": {
      "model": "Unit",
      "timestamps": { "createdAt": true, "updatedAt": false },
      "fields": {
        "id": { "type": "String", "required": true, "unique": true },
        "name": { "type": "String", "required": true, "unique": true },
        "symbol": { "type": "String", "required": true }
      }
    },

    "lidcolors": {
      "model": "LidColor",
      "timestamps": { "createdAt": true, "updatedAt": false },
      "fields": {
        "id": { "type": "String", "required": true, "unique": true },
        "color": { "type": "String", "required": true, "unique": true },
        "colorCode": { "type": "String", "default": "" },
        "order": { "type": "Number", "default": 0 }
      }
    },

    "materials": {
      "model": "Material",
      "timestamps": { "createdAt": true, "updatedAt": true },
      "fields": {
        "id": { "type": "String", "required": true, "unique": true },
        "name": { "type": "String", "required": true, "unique": true },
        "usage": { "type": "String", "required": true, "enum": ["body", "lid", "both"], "default": "both" },
        "description": { "type": "String", "default": "" }
      }
    },

    "lidtypes": {
      "model": "LidType",
      "timestamps": { "createdAt": true, "updatedAt": true },
      "fields": {
        "id": { "type": "String", "required": true, "unique": true },
        "name": { "type": "String", "required": true, "unique": true },
        "description": { "type": "String", "default": "" }
      }
    },

    "lidvariants": {
      "model": "LidVariant",
      "timestamps": { "createdAt": true, "updatedAt": true },
      "fields": {
        "id": { "type": "String", "required": true, "unique": true },
        "name": { "type": "String", "required": true, "unique": true },
        "description": { "type": "String", "default": "" }
      }
    },

    "pricetypes": {
      "model": "PriceType",
      "timestamps": { "createdAt": true, "updatedAt": false },
      "fields": {
        "id": { "type": "String", "required": true, "unique": true },
        "name": { "type": "String", "required": true, "unique": true },
        "description": { "type": "String", "default": "" }
      }
    },

    "promos": {
      "model": "Promo",
      "timestamps": { "createdAt": true, "updatedAt": true },
      "fields": {
        "id": { "type": "String", "required": true, "unique": true },
        "promoCode": { "type": "String", "unique": true, "sparse": true },
        "promoName": { "type": "String", "required": true },
        "description": { "type": "String", "default": "" },
        "promoType": { "type": "String", "required": true, "enum": ["percentage", "nominal"], "default": "percentage" },
        "promoValue": { "type": "Number", "required": true },
        "minQuantity": { "type": "Number", "required": true, "default": 1 },
        "productId": { "type": "String", "default": null, "ref": "products" },
        "lidColorId": { "type": "String", "default": null, "ref": "lidcolors" },
        "categoryId": { "type": "String", "default": null, "ref": "categories" },
        "validFrom": { "type": "Date", "required": true },
        "validUntil": { "type": "Date", "default": null },
        "maxUsage": { "type": "Number", "default": null },
        "usedCount": { "type": "Number", "default": 0 },
        "isActive": { "type": "Boolean", "default": true }
      },
      "indexes": [
        { "fields": { "isActive": 1, "validFrom": 1, "validUntil": 1 } }
      ]
    },

    "wishlists": {
      "model": "Wishlist",
      "timestamps": { "createdAt": true, "updatedAt": true },
      "fields": {
        "id": { "type": "String", "required": true, "unique": true },
        "userId": { "type": "String", "required": true, "ref": "users" },
        "productId": { "type": "String", "required": true, "ref": "products" },
        "lidColorId": { "type": "String", "default": null, "ref": "lidcolors" }
      },
      "indexes": [
        { "fields": { "userId": 1, "productId": 1, "lidColorId": 1 }, "unique": true }
      ]
    },

    "inquirycarts": {
      "model": "InquiryCart",
      "timestamps": { "createdAt": true, "updatedAt": true },
      "fields": {
        "id": { "type": "String", "required": true, "unique": true },
        "userId": { "type": "String", "required": true, "ref": "users" },
        "items": { "type": "Array<Embedded:InquiryCartItem>", "required": true, "default": [] },
        "status": { "type": "String", "required": true, "enum": ["draft", "sent", "archived"], "default": "draft" }
      },
      "embeddedSchemas": {
        "InquiryCartItem": {
          "_id": false,
          "fields": {
            "productId": { "type": "String", "required": true, "ref": "products" },
            "lidColorId": { "type": "String", "default": null, "ref": "lidcolors" },
            "priceTypeId": { "type": "String", "default": null, "ref": "pricetypes" },
            "quantity": { "type": "Number", "required": true, "default": 1, "min": 1 },
            "note": { "type": "String", "default": "" },
            "promoAppliedId": { "type": "String", "default": null, "ref": "promos" }
          }
        }
      },
      "indexes": [
        { "fields": { "userId": 1, "status": 1, "updatedAt": -1 } },
        { "fields": { "items.productId": 1 } }
      ]
    },

    "interactions": {
      "model": "Interaction",
      "timestamps": { "createdAt": true, "updatedAt": false },
      "fields": {
        "id": { "type": "String", "required": true, "unique": true },
        "userId": { "type": "String", "required": true, "ref": "users" },
        "productId": { "type": "String", "default": null, "ref": "products" },
        "pagePath": { "type": "String", "default": "" },
        "interactionType": { "type": "String", "required": true, "enum": ["page_view", "view", "detail_click", "whatsapp_share", "promo_click"] }
      },
      "indexes": [
        { "fields": { "productId": 1, "interactionType": 1, "createdAt": -1 } },
        { "fields": { "userId": 1, "createdAt": -1 } },
        { "fields": { "pagePath": 1, "interactionType": 1, "createdAt": -1 } }
      ]
    },

    "whatsapplogs": {
      "model": "WhatsAppLog",
      "timestamps": { "createdAt": true, "updatedAt": false },
      "fields": {
        "id": { "type": "String", "required": true, "unique": true },
        "userId": { "type": "String", "required": true, "ref": "users" },
        "message": { "type": "String", "required": true },
        "destinationNumber": { "type": "String", "required": true },
        "promoAppliedId": { "type": "String", "default": null, "ref": "promos" },
        "totalDiscount": { "type": "Number", "required": true, "default": 0 },
        "grandTotal": { "type": "Number", "required": true, "default": 0 },
        "details": { "type": "Array<Embedded:WhatsAppLogDetail>", "required": true, "default": [] }
      },
      "embeddedSchemas": {
        "WhatsAppLogDetail": {
          "_id": false,
          "fields": {
            "productId": { "type": "String", "required": true, "ref": "products" },
            "lidColorId": { "type": "String", "default": null, "ref": "lidcolors" },
            "quantity": { "type": "Number", "required": true, "default": 1 },
            "priceAtThatTime": { "type": "Number", "required": true },
            "subtotal": { "type": "Number", "required": true }
          }
        }
      },
      "indexes": [
        { "fields": { "userId": 1, "createdAt": -1 } }
      ]
    }
  },

  "relations": [
    { "from": "products.categoryId", "to": "categories.id", "type": "many-to-one" },
    { "from": "products.productTypeId", "to": "producttypes.id", "type": "many-to-one" },
    { "from": "products.unitId", "to": "units.id", "type": "many-to-one" },
    { "from": "products.lidMaterial", "to": "materials.id", "type": "many-to-one" },
    { "from": "products.bodyMaterial", "to": "materials.id", "type": "many-to-one" },
    { "from": "products.lidVariant", "to": "lidvariants.id", "type": "many-to-one" },
    { "from": "products.lidType", "to": "lidtypes.id", "type": "many-to-one" },
    { "from": "products.prices[].lidColorId", "to": "lidcolors.id", "type": "many-to-one" },
    { "from": "products.prices[].priceTypeId", "to": "pricetypes.id", "type": "many-to-one" },
    { "from": "promos.productId", "to": "products.id", "type": "many-to-one" },
    { "from": "promos.lidColorId", "to": "lidcolors.id", "type": "many-to-one" },
    { "from": "promos.categoryId", "to": "categories.id", "type": "many-to-one" },
    { "from": "wishlists.userId", "to": "users.id", "type": "many-to-one" },
    { "from": "wishlists.productId", "to": "products.id", "type": "many-to-one" },
    { "from": "wishlists.lidColorId", "to": "lidcolors.id", "type": "many-to-one" },
    { "from": "inquirycarts.userId", "to": "users.id", "type": "many-to-one" },
    { "from": "inquirycarts.items[].productId", "to": "products.id", "type": "many-to-one" },
    { "from": "inquirycarts.items[].lidColorId", "to": "lidcolors.id", "type": "many-to-one" },
    { "from": "inquirycarts.items[].priceTypeId", "to": "pricetypes.id", "type": "many-to-one" },
    { "from": "inquirycarts.items[].promoAppliedId", "to": "promos.id", "type": "many-to-one" },
    { "from": "interactions.userId", "to": "users.id", "type": "many-to-one" },
    { "from": "interactions.productId", "to": "products.id", "type": "many-to-one" },
    { "from": "whatsapplogs.userId", "to": "users.id", "type": "many-to-one" },
    { "from": "whatsapplogs.promoAppliedId", "to": "promos.id", "type": "many-to-one" },
    { "from": "whatsapplogs.details[].productId", "to": "products.id", "type": "many-to-one" },
    { "from": "whatsapplogs.details[].lidColorId", "to": "lidcolors.id", "type": "many-to-one" }
  ]
}
